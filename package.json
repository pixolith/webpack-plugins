{
    "name": "root",
    "private": true,
    "type": "module",
    "devDependencies": {
        "@pixolith/webpack-sw6-config": "11.0.8",
        "eslint": "^8.36.0",
        "lerna": "^6.5.1",
        "prettier": "^2.8.4"
    },
    "scripts": {
        "clean": "rimraf -g 'custom/plugins/*/src/Resources/views/administration/**/*.twig' 'vendor/pxsw/*/src/Resources/views/administration/**/*.twig' 'public/js/*.*' 'public/css/*.*' 'var/px_plugins.json'",
        "dev": "npm run sf:dev",
        "sf:dev": "npm run clean && cross-env SHOPWARE_MODE=storefront NODE_ENV=development webpack-dev-server --hot",
        "sf:build": "cross-env SHOPWARE_MODE=storefront NODE_ENV=production webpack",
        "build": "npm run clean && concurrently \"npm run sf:build\" \"npm run admin:build\" \"npm run admin:build:sw\"",
        "admin": "npm run admin:dev",
        "admin:dev": "ddev exec bash bin/watch-administration.sh",
        "admin:build": "cross-env SHOPWARE_MODE=administration NODE_ENV=production webpack",
        "admin:build:sw": "command -v ddev >/dev/null 2>&1 && ddev exec bash bin/build-administration.sh || npm run admin:cibuild",
        "admin:cibuild": "CI=1 SHOPWARE_SKIP_ENTITY_SCHEMA_DUMP=1 SHOPWARE_SKIP_ASSET_COPY=1 bash bin/build-administration.sh"
    },
    "browserslist": {
        "storefront": [
            ">= 0.5%",
            "last 2 major versions",
            "not dead"
        ],
        "administration": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "prettier": "./packages/prettier-config/src/index.json",
    "eslintConfig": {
        "extends": [
            "./packages/eslint-config-sw6/src/index.js"
        ]
    },
    "dependencies": {
        "autoprefixer": "^10.4.20"
    }
}
